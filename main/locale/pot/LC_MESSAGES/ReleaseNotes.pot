msgstr ""

#: ../../../ReleaseNotes.rst:809
msgid ""
"Tenstorrent Ascalon D8 was renamed to Ascalon X. Use `tt-ascalon-x` with `-"
"mcpu` or `-mtune`."
msgstr ""

