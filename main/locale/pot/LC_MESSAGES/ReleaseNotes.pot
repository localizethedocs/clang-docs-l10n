msgid "OpenMP Support"
msgstr ""

#: ../../../ReleaseNotes.rst:945
msgid ""
"Added support for ``transparent`` clause in task and taskloop directives."
msgstr ""

#: ../../../ReleaseNotes.rst:946
msgid ""
"Added support for ``use_device_ptr`` clause to accept an optional "
"``fallback`` modifier (``fb_nullify`` or ``fb_preserve``) with OpenMP >= 61."
msgstr ""

#: ../../../ReleaseNotes.rst:948
msgid ""
"Added support for ``local`` clause with declare_target directive when OpenMP "
">= 60."
msgstr ""

#: ../../../ReleaseNotes.rst:952
msgid "SYCL Support"
msgstr ""

#: ../../../ReleaseNotes.rst:953
msgid ""
"Clang now assumes default target for SYCL device compilation is 64-bit SPIR-"
"V and it now diagnoses if a non-supporting target is specified via command "
"line. (#GH167358)"
msgstr ""

#: ../../../ReleaseNotes.rst:958
msgid "Improvements"
msgstr ""

#: ../../../ReleaseNotes.rst:959
msgid "Improved substitution performance in concept checking. (#GH172266)"
msgstr ""

#: ../../../ReleaseNotes.rst:961
msgid ""
"Clang now preserves the left-hand side of a binary expression (such as an "
"assignment or comparison) in a ``RecoveryExpr`` when the right-hand side "
"fails to parse. This improves IDE features like go-to-definition in "
"``clangd``."
msgstr ""

