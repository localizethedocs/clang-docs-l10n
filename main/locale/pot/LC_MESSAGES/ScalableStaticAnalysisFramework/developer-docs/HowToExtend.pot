msgstr ""

#: ../../../ScalableStaticAnalysisFramework/developer-docs/HowToExtend.rst:46
msgid "Step 2: Register the extractor"
msgstr ""

#: ../../../ScalableStaticAnalysisFramework/developer-docs/HowToExtend.rst:64
msgid ""
"The ``\"MyExtractor\"`` string is the name users pass to ``--ssaf-extract-"
"summaries=MyExtractor``."
msgstr ""

#: ../../../ScalableStaticAnalysisFramework/developer-docs/HowToExtend.rst:67
msgid "Step 3: Add the force-linker anchor"
msgstr ""

#: ../../../ScalableStaticAnalysisFramework/developer-docs/HowToExtend.rst:69
msgid ""
"See :doc:`ForceLinkerHeaders` for a full explanation of why this is needed."
msgstr ""

